################################
# Application
################################
APP_NAME=HealthcareSystem
APP_ENV=local
APP_KEY=base64:your_app_key_here
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000


################################
# Logging
################################
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug


################################
# Database (MySQL)
################################
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=healthcare_system
DB_USERNAME=root
DB_PASSWORD=


################################
# Ethereum Blockchain
################################
ETH_NODE_URL=http://127.0.0.1:7545
ETH_WALLET_ADDRESS=0xYourWalletAddress
ETH_PRIVATE_KEY=YourPrivateKey
ETH_CONTRACT_ADDRESS=0xYourContractAddress


################################
# File Storage (Backblaze B2)
################################
FILESYSTEM_DISK=s3

AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-west-004
AWS_BUCKET=healthcare-data
AWS_ENDPOINT=https://s3.us-west-004.backblazeb2.com
AWS_USE_PATH_STYLE_ENDPOINT=true


################################
# Cache / Session / Queue
################################
BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120


################################
# Sanctum Authentication
################################
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,127.0.0.1:8000
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false


################################
# Redis
################################
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379


################################
# Mail (Development)
################################
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"


################################
# Pusher (Optional)
################################
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1